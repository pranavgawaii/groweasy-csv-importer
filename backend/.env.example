# Groq API key — get a free one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the model (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Port the API listens on (defaults to 4000)
# PORT=4000

# Allowed CORS origin for the frontend (defaults to "*").
# Set this to your deployed frontend URL in production, e.g. https://your-app.vercel.app
# CORS_ORIGIN=http://localhost:3000
